{
  "name": "blp-previewer",
  "displayName": "BLP Previewer",
  "description": "Preview BLP2 texture files in VS Code",
  "version": "0.0.1",
  "publisher": "BitAtWork",
  "repository": { "type": "git", "url": "" },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "blpPreviewer.blp",
        "displayName": "BLP Previewer",
        "selector": [
          { "filenamePattern": "*.blp" }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.0.0"
  }
}
